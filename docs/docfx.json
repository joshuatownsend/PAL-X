{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "src/Pal.Application/Pal.Application.csproj",
            "src/Pal.Engine/Pal.Engine.csproj",
            "src/Pal.Packs/Pal.Packs.csproj",
            "src/Pal.Reporting/Pal.Reporting.csproj"
          ],
          "src": "../dotnet"
        }
      ],
      "dest": "reference/api",
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "includePrivateMembers": false,
      "includeExplicitInterfaceImplementations": false,
      "memberLayout": "samePage",
      "namespaceLayout": "flattened"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**",
          "internal/**",
          "obj/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "_static/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "PAL-X",
      "_appTitle": "PAL-X Documentation",
      "_enableSearch": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/joshuatownsend/PAL-X",
        "branch": "main"
      }
    }
  }
}
