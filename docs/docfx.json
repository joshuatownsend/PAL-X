{
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**",
          "internal/**",
          "obj/**",
          "reference/api/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "_static/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "PAL-X",
      "_appTitle": "PAL-X Documentation",
      "_enableSearch": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/joshuatownsend/PAL-X",
        "branch": "main"
      }
    }
  }
}
