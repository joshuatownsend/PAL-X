# Copy this file to .env and fill in values before running docker compose up.

# Postgres password — used by both the postgres container and the api connection string.
# Must not contain semicolons (;) — the password is inlined into a semicolon-delimited
# Npgsql connection string and will cause a parse error if semicolons are present.
POSTGRES_PASSWORD=change-me-in-production

# Bootstrap admin account.  Set on first run only; ignored if admin@pal.local already exists.
# Must meet the password policy: minimum 10 characters.
PAL_BOOTSTRAP_ADMIN_PASSWORD=change-me-in-production

# Optional: override the Postgres host port (defaults to 5432).  Useful when a native
# PostgreSQL service is already running on the host machine and would otherwise collide.
# When set, also override the API connection string for local `dotnet run` (see README).
# POSTGRES_PORT_HOST=5433

# Optional: auto-purge old data (0 = disabled, which is the default).
# RETENTION_JOB_DAYS=90
# RETENTION_AUDIT_DAYS=365
