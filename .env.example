# Copy this file to .env and fill in values before running docker compose up.

# Postgres password — used by both the postgres container and the api connection string.
POSTGRES_PASSWORD=change-me-in-production

# Bootstrap admin account.  Set on first run only; ignored if admin@pal.local already exists.
# Must meet the password policy: minimum 10 characters.
PAL_BOOTSTRAP_ADMIN_PASSWORD=change-me-in-production
