@page "/correlations"
@inject CorrelationService CorrelSvc

<PageTitle>Correlations</PageTitle>
<h1>Signal Correlations</h1>

<div class="compare-form">
    <div class="form-row">
        <label>
            Last <input type="number" min="2" max="100" @bind="_window" style="width:5em" /> completed jobs
        </label>
        <button class="btn-primary" @onclick="RunAnalysis" disabled="@_running">Analyze</button>
    </div>
    @if (_errorMessage is not null)
    {
        <p class="error">@_errorMessage</p>
    }
</div>

@if (_result is not null)
{
    @if (_result.JobCount < 2)
    {
        <p class="healthy">At least 2 completed runs are needed to compute correlations.</p>
    }
    else
    {
        <div class="compare-summary">
            <p>
                Analyzed <strong>@_result.JobCount</strong> runs —
                @_result.WindowStart.LocalDateTime.ToString("yyyy-MM-dd") to
                @_result.WindowEnd.LocalDateTime.ToString("yyyy-MM-dd")
            </p>
        </div>

        @if (_result.Pairs.Count == 0)
        {
            <p class="healthy">No co-occurring findings in the selected window.</p>
        }
        else
        {
            <table class="jobs-table">
                <thead>
                    <tr>
                        <th>Signal A</th>
                        <th>Direction</th>
                        <th>Signal B</th>
                        <th>Direction</th>
                        <th>Co-runs</th>
                        <th>Score</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in _result.Pairs)
                    {
                        <tr>
                            <td>@p.KeyA</td>
                            <td><span class="diff-badge trend-@p.DirectionA">@p.DirectionA</span></td>
                            <td>@p.KeyB</td>
                            <td><span class="diff-badge trend-@p.DirectionB">@p.DirectionB</span></td>
                            <td>@p.CoRunCount / @p.TotalRuns</td>
                            <td>@p.CoScore.ToString("P0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }
}

@code {
    private int _window = 10;
    private bool _running;
    private string? _errorMessage;
    private CorrelationResultDto? _result;

    protected override async Task OnInitializedAsync() => await RunAnalysis();

    private async Task RunAnalysis()
    {
        _errorMessage = null;
        _running = true;
        try
        {
            _result = await CorrelSvc.ComputeAsync(_window);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error computing correlations: {ex.Message}";
        }
        finally
        {
            _running = false;
        }
    }
}
