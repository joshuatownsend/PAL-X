@page "/jobs/{Id:guid}"
@attribute [Authorize]
@inject IAnalysisRepository AnalysisRepo
@implements IDisposable

<PageTitle>Job @Id.ToString("N")[..8]</PageTitle>

@if (_job is null)
{
    <p>Loading...</p>
}
else
{
    <h1>Job <code>@_job.Id.ToString("N")[..8]</code></h1>
    <div class="job-meta">
        <p>Status: <span class="status-badge status-@_job.Status">@_job.Status</span>
            @if (_job.IsBaseline)
            {
                var typeLabel = _job.BaselineType is not null ? $" · {_job.BaselineType}" : "";
                var nameLabel = _job.BaselineLabel is not null ? $": {_job.BaselineLabel}{typeLabel}" : typeLabel;
                <span class="baseline-badge">Baseline@(nameLabel)</span>
            }
        </p>
        <p>Created: @_job.CreatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</p>
        @if (_job.StartedAt is not null)
        {
            <p>Started: @_job.StartedAt.Value.LocalDateTime.ToString("HH:mm:ss")</p>
        }
        @if (_job.CompletedAt is not null)
        {
            <p>Completed: @_job.CompletedAt.Value.LocalDateTime.ToString("HH:mm:ss")</p>
        }
        @if (_job.FailureReason is not null)
        {
            <p class="error">Failure: @_job.FailureReason</p>
        }
        <p>Packs: @string.Join(", ", _job.Packs.Select(p => $"{p.PackId} v{p.PackVersion}"))</p>
        @if (_job.Status == "completed")
        {
            <div class="baseline-controls">
                @if (!_job.IsBaseline)
                {
                    @if (!_showBaselineForm)
                    {
                        <button class="btn-secondary" @onclick="() => _showBaselineForm = true">Set as Baseline</button>
                    }
                    else
                    {
                        <div class="baseline-form">
                            <label>Label <input @bind="_baselineLabel" placeholder="e.g. WEB-01" /></label>
                            <label>Type
                                <select @bind="_baselineType">
                                    <option value="">— none —</option>
                                    <option value="machine">Machine</option>
                                    <option value="role">Role</option>
                                    <option value="workload">Workload</option>
                                    <option value="release">Release</option>
                                </select>
                            </label>
                            <label>Context JSON <input @bind="_baselineContextJson" placeholder='{"machine":"WEB-01"}' /></label>
                            <button class="btn-primary" @onclick="SetAsBaseline">Confirm</button>
                            <button class="btn-secondary" @onclick="() => { _showBaselineForm = false; _baselineFormError = null; }">Cancel</button>
                            @if (_baselineFormError is not null)
                            {
                                <p class="error">@_baselineFormError</p>
                            }
                        </div>
                    }
                }
                else
                {
                    <button class="btn-secondary" @onclick="ClearBaseline">Clear Baseline</button>
                    <a href="/compare?baseline=@_job.Id" class="btn-primary">Compare against this baseline</a>
                }
            </div>
        }
    </div>

    @if (_job.Status == "completed" && _result is not null)
    {
        <div class="report-links">
            <a href="/analysis/@_job.Id/report?format=json" target="_blank">Download JSON Report</a>
            &nbsp;|&nbsp;
            <a href="/analysis/@_job.Id/report?format=html" target="_blank">Download HTML Report</a>
        </div>

        <DiagnosticsSection JobId="@_job.Id" />

        <FindingsExplorer FindingsJson="@_result.FindingsJson" />
    }
    else if (_job.Status is "queued" or "running")
    {
        <p>Analysis in progress...</p>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }
    [Inject] private NavigationManager Nav { get; set; } = null!;

    private AnalysisJobDto? _job;
    private AnalysisResultDto? _result;
    private Timer? _timer;

    private static readonly HashSet<string> ValidBaselineTypes = ["machine", "role", "workload", "release"];

    private bool _showBaselineForm;
    private string? _baselineLabel;
    private string? _baselineType;
    private string? _baselineContextJson;
    private string? _baselineFormError;

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        _job = await AnalysisRepo.GetJobAsync(Id);
        if (_job?.Status == "completed")
            _result = await AnalysisRepo.GetResultAsync(Id);

        if (_job?.Status is "queued" or "running")
        {
            _timer ??= new Timer(async _ =>
            {
                await RefreshAsync();
                await InvokeAsync(StateHasChanged);
            }, null, TimeSpan.FromSeconds(3), TimeSpan.FromSeconds(3));
        }
        else
        {
            _timer?.Dispose();
            _timer = null;
        }
    }

    private async Task SetAsBaseline()
    {
        _baselineFormError = null;
        var type = NullIfEmpty(_baselineType);
        if (type is not null && !ValidBaselineTypes.Contains(type))
        {
            _baselineFormError = $"Type must be one of: {string.Join(", ", ValidBaselineTypes)}";
            return;
        }
        var contextJson = NullIfEmpty(_baselineContextJson);
        if (contextJson is not null && !TryNormalizeJson(contextJson, out contextJson))
        {
            _baselineFormError = "Context JSON must be valid JSON";
            return;
        }
        await AnalysisRepo.SetBaselineAsync(Id, true, NullIfEmpty(_baselineLabel), type, contextJson);
        _showBaselineForm = false;
        await RefreshAsync();
    }

    private static string? NullIfEmpty(string? s) => string.IsNullOrEmpty(s) ? null : s;

    private static bool TryNormalizeJson(string json, out string? normalized)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            normalized = System.Text.Json.JsonSerializer.Serialize(doc.RootElement);
            return true;
        }
        catch { normalized = null; return false; }
    }

    private async Task ClearBaseline()
    {
        await AnalysisRepo.SetBaselineAsync(Id, false, null);
        await RefreshAsync();
    }

    public void Dispose() => _timer?.Dispose();
}
