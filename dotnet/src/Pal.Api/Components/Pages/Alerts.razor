@page "/alerts"
@attribute [Authorize]
@inject IAlertService AlertService
@implements IAsyncDisposable

<PageTitle>Alerts</PageTitle>
<h1>Alerts</h1>

<div class="filter-row">
    <label>Status:
        <select @bind="_statusFilter" @bind:after="LoadAsync">
            <option value="">All</option>
            <option value="open">Open</option>
            <option value="acknowledged">Acknowledged</option>
            <option value="resolved">Resolved</option>
        </select>
    </label>
    &nbsp;
    <label>Severity:
        <select @bind="_severityFilter" @bind:after="LoadAsync">
            <option value="">All</option>
            <option value="critical">Critical</option>
            <option value="warning">Warning</option>
            <option value="informational">Informational</option>
        </select>
    </label>
</div>

@if (_alerts is null)
{
    <p>Loading...</p>
}
else if (_alerts.Count == 0)
{
    <p class="healthy">No alerts match the current filter.</p>
}
else
{
    <table class="jobs-table">
        <thead>
            <tr>
                <th>Severity</th>
                <th>Rule</th>
                <th>Title</th>
                <th>Status</th>
                <th>Triggered</th>
                <th>Last Seen</th>
                <th>Job</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in _alerts)
            {
                var snoozedActive = a.SnoozedUntil is { } until && until > DateTimeOffset.UtcNow;
                <tr>
                    <td>
                        <span class="sev-badge sev-@a.Severity">@a.Severity</span>
                        @if (a.PolicyApplied is not null)
                        {
                            <span class="policy-badge" title="Adjusted by Phase 4 policy rule">@a.PolicyApplied</span>
                        }
                    </td>
                    <td><code>@a.RuleId</code></td>
                    <td>@a.Title</td>
                    <td>
                        <span class="status-badge alert-@a.Status">@a.Status</span>
                        @if (snoozedActive)
                        {
                            <span class="snooze-badge" title="Snoozed until @a.SnoozedUntil!.Value.ToString("u")">
                                snoozed → @a.SnoozedUntil!.Value.LocalDateTime.ToString("MMM d HH:mm")
                            </span>
                        }
                    </td>
                    <td title="@a.TriggeredAt.ToString("u")">@a.TriggeredAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                    <td title="@a.LastSeenAt.ToString("u")">@a.LastSeenAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                    <td><a href="/jobs/@a.LatestJobId">@a.LatestJobId.ToString("N")[..8]</a></td>
                    <td class="alert-actions">
                        @if (a.Status == "open")
                        {
                            <button class="btn-secondary" @onclick="() => AcknowledgeAsync(a.Id)">Ack</button>
                        }
                        @if (a.Status != "resolved")
                        {
                            <button class="btn-secondary" @onclick="() => BeginResolve(a.Id)">Resolve</button>
                            @if (snoozedActive)
                            {
                                <button class="btn-secondary" @onclick="() => UnsnoozeAsync(a.Id)">Unsnooze</button>
                            }
                            else
                            {
                                <button class="btn-secondary" @onclick="() => BeginSnooze(a.Id)">Snooze</button>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_resolveId is not null)
{
    <div class="resolve-dialog">
        <strong>Resolve alert</strong>
        <label>Note (optional):
            <input type="text" @bind="_resolveNote" placeholder="Optional resolution note" />
        </label>
        <div class="resolve-actions">
            <button class="btn-primary" @onclick="ConfirmResolveAsync">Confirm</button>
            <button class="btn-secondary" @onclick="CancelResolve">Cancel</button>
        </div>
    </div>
}

@if (_snoozeId is not null)
{
    <div class="resolve-dialog">
        <strong>Snooze alert</strong>
        <p class="version">Suppress notifications for this alert. The alert remains visible and continues to update on each rule re-fire.</p>
        <div class="resolve-actions">
            <button class="btn-secondary" @onclick="() => SetSnoozePreset(60)">1h</button>
            <button class="btn-secondary" @onclick="() => SetSnoozePreset(240)">4h</button>
            <button class="btn-secondary" @onclick="() => SetSnoozePreset(1440)">1d</button>
            <button class="btn-secondary" @onclick="() => SetSnoozePreset(10080)">1w</button>
        </div>
        <label>Custom (minutes from now, max 30 days):
            <input type="number" min="1" max="43200" @bind="_snoozeMinutes" />
        </label>
        @if (!string.IsNullOrEmpty(_snoozeError))
        {
            <p class="error">@_snoozeError</p>
        }
        <div class="resolve-actions">
            <button class="btn-primary" @onclick="ConfirmSnoozeAsync">Confirm</button>
            <button class="btn-secondary" @onclick="CancelSnooze">Cancel</button>
        </div>
    </div>
}

@code {
    private List<AlertDto>? _alerts;
    private string _statusFilter = "open";
    private string _severityFilter = "";
    private readonly CancellationTokenSource _cts = new();

    private Guid? _resolveId;
    private string _resolveNote = "";

    private Guid? _snoozeId;
    private int _snoozeMinutes = 60;
    private string _snoozeError = "";

    [Inject] private NavigationManager Nav { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _ = PollAsync(_cts.Token);
    }

    private async Task PollAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(10));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                await LoadAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task LoadAsync()
    {
        var status = string.IsNullOrEmpty(_statusFilter) ? null : _statusFilter;
        var severity = string.IsNullOrEmpty(_severityFilter) ? null : _severityFilter;
        _alerts = (await AlertService.ListAsync(status, severity)).ToList();
    }

    private async Task AcknowledgeAsync(Guid id)
    {
        await AlertService.AcknowledgeAsync(id);
        await LoadAsync();
    }

    private void BeginResolve(Guid id)
    {
        _resolveId = id;
        _resolveNote = "";
    }

    private async Task ConfirmResolveAsync()
    {
        if (_resolveId is null) return;
        await AlertService.ResolveAsync(_resolveId.Value, string.IsNullOrWhiteSpace(_resolveNote) ? null : _resolveNote);
        _resolveId = null;
        await LoadAsync();
    }

    private void CancelResolve()
    {
        _resolveId = null;
        _resolveNote = "";
    }

    private void BeginSnooze(Guid id)
    {
        _snoozeId = id;
        _snoozeMinutes = 60;
        _snoozeError = "";
    }

    private void SetSnoozePreset(int minutes) => _snoozeMinutes = minutes;

    private async Task ConfirmSnoozeAsync()
    {
        if (_snoozeId is null) return;
        if (_snoozeMinutes < 1 || _snoozeMinutes > 43200)
        {
            _snoozeError = "Duration must be between 1 minute and 30 days.";
            return;
        }
        await AlertService.SetSnoozedUntilAsync(_snoozeId.Value, DateTimeOffset.UtcNow.AddMinutes(_snoozeMinutes));
        _snoozeId = null;
        await LoadAsync();
    }

    private void CancelSnooze()
    {
        _snoozeId = null;
        _snoozeError = "";
    }

    private async Task UnsnoozeAsync(Guid id)
    {
        await AlertService.SetSnoozedUntilAsync(id, null);
        await LoadAsync();
    }

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
    }
}
