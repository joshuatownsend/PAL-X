@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="page">
    <nav class="sidebar">
        <div class="nav-brand">PAL</div>
        <ul class="nav-links">
            <li><NavLink href="/submit" Match="NavLinkMatch.All">Submit Analysis</NavLink></li>
            <li><NavLink href="/jobs">Jobs</NavLink></li>
            <li><NavLink href="/compare">Compare</NavLink></li>
            <li><NavLink href="/baselines">Baselines</NavLink></li>
            <li><NavLink href="/trends">Trends</NavLink></li>
            <li><NavLink href="/correlations">Correlations</NavLink></li>
            <li><NavLink href="/alerts">Alerts</NavLink></li>
            <li><NavLink href="/webhooks">Webhooks</NavLink></li>
        </ul>

        <div class="nav-footer">
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <NavLink href="/account/users" class="nav-admin-link">Users</NavLink>
                </Authorized>
            </AuthorizeView>
            <NavLink href="/account/tokens" class="nav-admin-link">API Tokens</NavLink>
            <AuthorizeView>
                <Authorized>
                    <span class="nav-user">@context.User.Identity?.Name</span>
                    <button class="btn-logout" @onclick="Logout">Sign out</button>
                </Authorized>
            </AuthorizeView>
        </div>
    </nav>
    <main class="content">
        @Body
    </main>
</div>

@code {
    private void Logout() => Nav.NavigateTo("/account/logout", forceLoad: true);
}
